# Frontend env vars — copy this file to .env and fill in per client.
# Vite will inject %VITE_*% into index.html at build time.

# Backend URL — the Render-deployed backend for this client
VITE_API_BASE=https://CLIENT-backend.onrender.com

# Brand text — appears in <title>, PWA install name, and apple-touch UI title
VITE_CLIENT_NAME=Atlas Dashboard

# Description — used in <meta name="description"> and search results
VITE_CLIENT_DESCRIPTION=Lead-gen dashboard powered by Atlas AI Group
